{
	"name": "artefact",
	"module": "src/main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"fix": "bun run format && bun run check && bun run lint",
		"check": "bun x --bun @biomejs/biome check --fix .",
		"format": "bun x --bun @biomejs/biome format --fix .",
		"lint": "bun x --bun @biomejs/biome lint --fix .",
		"start": "bun run src/main.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	}
}
