{
	"name": "artefact-monorepo",
	"version": "0.1.0",
	"private": true,
	"workspaces": [
		"packages/**/*"
	],
	"scripts": {
		"fix": "bun run --cwd packages/artefact/core fix",
		"build": "bun run --cwd packages/artefact/core build",
		"seed": "bun run --cwd packages/artefact/core seed",
		"start": "bun run --cwd packages/artefact/core start",
		"test": "bun test packages/**/*"
	}
}
